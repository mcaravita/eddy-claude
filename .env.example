# Copy to .env and adjust as needed: `cp .env.example .env`

# --- Network exposure (docker-compose "web" service) ---
# Host port published for the web UI.
HOST_PORT=8080

# Host IP to bind the published port to. Defaults to 0.0.0.0 (all interfaces).
# For LAN hardening, set this to the host's LAN IP (e.g. 192.168.1.20) so the
# port is not reachable from other interfaces (see README security notes).
HOST_BIND_IP=0.0.0.0

# --- Frontend build-time config ---
# Number of recent exchanges shown in the client-side history.
VITE_HISTORY_SIZE=10

# --- Backend persistence (roadmap, disabled by default — see AGENTS.md §8ter) ---
# EDDY_PERSISTENCE=memory
